{
  "name": "fortress-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:test": "DATABASE_URL=$DATABASE_URL_TEST tsx src/db/migrate.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@fortress/types": "*",
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "argon2": "^0.40.0",
    "fastify": "^4.28.0",
    "jsonwebtoken": "^9.0.0",
    "otpauth": "^9.3.0",
    "pg": "^8.12.0",
    "drizzle-orm": "^0.31.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.22.0",
    "tsx": "^4.16.0",
    "vitest": "^1.6.0"
  }
}
