# Fortress Server Environment Variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/fortress_dev
DATABASE_URL_TEST=postgresql://user:pass@localhost:5432/fortress_test

# JWT (generate random strings for production)
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production

# Email (console = logs to stdout in dev)
EMAIL_PROVIDER=console
EMAIL_API_KEY=

# Rate limiting (auth attempts per minute per IP)
RATE_LIMIT_AUTH=5
