{
  "name": "fortress",
  "private": true,
  "workspaces": [
    "packages/*",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build:types && npm run build:client && npm run build:server",
    "build:types": "npm run build -w @fortress/types",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server",
    "test": "npm run test:types && npm run test:client && npm run test:server",
    "test:client": "npm run test -w client",
    "test:server": "npm run test -w server",
    "test:types": "npm run typecheck -w @fortress/types",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "db:migrate": "npm run db:migrate -w server",
    "db:migrate:test": "npm run db:migrate:test -w server",
    "db:reset": "npm run db:reset -w server"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
